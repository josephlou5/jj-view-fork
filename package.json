{
    "name": "jj-view",
    "publisher": "jj-view",
    "displayName": "JJ View",
    "description": "Integrates Jujutsu (jj) version control into VS Code.",
    "version": "1.18.1",
    "repository": {
        "type": "git",
        "url": "https://github.com/brychanrobot/jj-view"
    },
    "icon": "media/icon.png",
    "engines": {
        "vscode": "^1.104.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "workspaceContains:.jj"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "icons": {
            "jj-icon-squash-into": {
                "description": "Squash into Ancestor icon",
                "default": {
                    "fontPath": "./media/custom-icons/jj-view-icons.woff",
                    "fontCharacter": "\\f101"
                }
            }
        },
        "configuration": {
            "title": "JJ View",
            "properties": {
                "jj-view.refreshDebounceMillis": {
                    "type": "number",
                    "default": 100,
                    "description": "Base debounce time (ms) for SCM refresh based on file events."
                },
                "jj-view.refreshDebounceMaxMultiplier": {
                    "type": "number",
                    "default": 4,
                    "minimum": 1,
                    "description": "Maximum multiplier for the debounce timeout when events continue to occur."
                },
                "jj-view.fileWatcherMode": {
                    "type": "string",
                    "default": "polling",
                    "enum": [
                        "polling",
                        "watch"
                    ],
                    "enumDescriptions": [
                        "Use periodic status checks (default).",
                        "Use a file watcher (parcel-watcher) for efficient updates (only on changes)."
                    ],
                    "description": "Controls how the extension detects external file changes."
                },
                "jj-view.gerrit.host": {
                    "type": "string",
                    "description": "Gerrit host URL (e.g., https://gerrit-review.googlesource.com). If not set, extension attempts to detect it from .gitreview or git remotes."
                },
                "jj-view.gerrit.project": {
                    "type": "string",
                    "description": "Gerrit project name. If not set, extension attempts to detect it from git remotes."
                },
                "jj-view.uploadCommand": {
                    "type": "string",
                    "description": "Custom command to run for upload. Example: 'git push'. The command will be prefixed with 'jj' and suffixed with '-r <revision>'."
                },
                "jj-view.minChangeIdLength": {
                    "type": "number",
                    "default": 1,
                    "minimum": 1,
                    "description": "Minimum number of characters to display for change IDs. This affects the unique prefix calculation and UI truncation."
                },
                "jj-view.maxMutableAncestors": {
                    "type": "number",
                    "default": 10,
                    "minimum": 0,
                    "description": "Maximum number of mutable ancestors to display in the SCM view."
                },
                "jj-view.logTheme": {
                    "type": "string",
                    "default": "default",
                    "enum": [
                        "default",
                        "oceanic",
                        "sunset",
                        "neon",
                        "pastel",
                        "monochrome"
                    ],
                    "description": "Color theme for the graph lanes in the JJ Log view."
                },
                "jj-view.commit.titleWidthRuler": {
                    "type": "number",
                    "default": 50,
                    "description": "Width at which to display a ruler in the commit details description editor for the title line."
                },
                "jj-view.commit.bodyWidthRuler": {
                    "type": "number",
                    "default": 72,
                    "description": "Width at which to display a ruler in the commit details description editor for the body."
                }
            }
        },
        "commands": [
            {
                "command": "jj-view.upload",
                "title": "Upload",
                "category": "JJ View",
                "icon": "$(cloud-upload)"
            },
            {
                "command": "jj-view.showCurrentChange",
                "title": "Show Current Change",
                "category": "JJ View",
                "icon": "$(eye)"
            },
            {
                "command": "jj-view.newMergeChange",
                "title": "New Merge Change",
                "category": "JJ View",
                "icon": "$(git-merge)"
            },
            {
                "command": "jj-view.new",
                "title": "New Change",
                "category": "JJ View",
                "icon": "$(plus)"
            },
            {
                "command": "jj-view.setDescription",
                "title": "Set Description",
                "category": "JJ View",
                "icon": "$(save)"
            },
            {
                "command": "jj-view.describePrompt",
                "title": "Set Description (Prompt)",
                "category": "JJ View",
                "icon": "$(save)"
            },
            {
                "command": "jj-view.commit",
                "title": "Commit",
                "category": "JJ View",
                "icon": "$(check)"
            },
            {
                "command": "jj-view.commitPrompt",
                "title": "Commit (Prompt)",
                "category": "JJ View",
                "icon": "$(check)"
            },
            {
                "command": "jj-view.refresh",
                "title": "Refresh",
                "category": "JJ View",
                "icon": "$(refresh)"
            },
            {
                "command": "jj-view.restore",
                "title": "Restore",
                "category": "JJ View",
                "icon": "$(discard)"
            },
            {
                "command": "jj-view.squash",
                "title": "Squash into Parent",
                "category": "JJ View",
                "icon": "$(arrow-down)"
            },
            {
                "command": "jj-view.squashInto",
                "title": "Squash into Ancestor",
                "category": "JJ View",
                "icon": "$(jj-icon-squash-into)"
            },
            {
                "command": "jj-view.moveToChild",
                "title": "Move to Child",
                "category": "JJ View",
                "icon": "$(arrow-up)"
            },
            {
                "command": "jj-view.openFile",
                "title": "Open File",
                "category": "JJ View",
                "icon": "$(go-to-file)"
            },
            {
                "command": "jj-view.undo",
                "title": "Undo",
                "category": "JJ View",
                "icon": "$(discard)"
            },
            {
                "command": "jj-view.duplicate",
                "title": "Duplicate",
                "category": "JJ View"
            },
            {
                "command": "jj-view.abandon",
                "title": "Abandon",
                "category": "JJ View",
                "icon": "$(trash)"
            },
            {
                "command": "jj-view.edit",
                "title": "Edit",
                "category": "JJ View",
                "icon": "$(edit)"
            },
            {
                "command": "jj-view.newBefore",
                "title": "New Before",
                "category": "JJ View",
                "icon": "$(source-control)"
            },
            {
                "command": "jj-view.moveToParentInDiff",
                "title": "Move to Parent",
                "category": "JJ View"
            },
            {
                "command": "jj-view.openMergeEditor",
                "title": "Open Merge Editor",
                "category": "JJ View"
            },
            {
                "command": "jj-view.completeSquash",
                "title": "Complete Squash",
                "category": "JJ View",
                "icon": "$(check)"
            },
            {
                "command": "jj-view.rebaseOntoSelected",
                "title": "Rebase onto Selected",
                "category": "JJ View",
                "icon": "$(git-merge)"
            },
            {
                "command": "jj-view.showDetails",
                "title": "Show Details",
                "category": "JJ View",
                "icon": "$(list-selection)"
            },
            {
                "command": "jj-view.discardChange",
                "title": "Discard Change",
                "category": "JJ View",
                "icon": "$(discard)"
            },
            {
                "command": "jj-view.squashChange",
                "title": "Squash Change to Parent",
                "category": "JJ View",
                "icon": "$(repo-pull)"
            },
            {
                "command": "jj-view.setBookmark",
                "title": "Set Bookmark",
                "category": "JJ View",
                "icon": "$(bookmark)"
            },
            {
                "command": "jj-view.absorb",
                "title": "Absorb",
                "category": "JJ View",
                "icon": "$(magnet)"
            },
            {
                "command": "jj-view.showMultiFileDiff",
                "title": "Show Multi-File Diff",
                "category": "JJ View",
                "icon": "$(diff-multiple)"
            }
        ],
        "keybindings": [
            {
                "command": "jj-view.setDescription",
                "key": "ctrl+s",
                "mac": "cmd+s",
                "when": "scmProvider == 'jj' && editorLangId == 'scminput'"
            },
            {
                "command": "jj-view.commit",
                "key": "ctrl+enter",
                "mac": "cmd+enter",
                "when": "scmProvider == 'jj' && editorLangId == 'scminput'"
            }
        ],
        "menus": {
            "view/title": [
                {
                    "command": "jj-view.undo",
                    "group": "navigation",
                    "when": "view == jj-view.logView"
                },
                {
                    "command": "jj-view.abandon",
                    "group": "navigation",
                    "when": "view == jj-view.logView && jj.selection.allowAbandon"
                },
                {
                    "command": "jj-view.newMergeChange",
                    "group": "navigation",
                    "when": "view == jj-view.logView && jj.selection.allowMerge"
                },
                {
                    "command": "jj-view.newBefore",
                    "group": "navigation",
                    "when": "view == jj-view.logView && jj.selection.allowNewBefore"
                }
            ],
            "webview/context": [
                {
                    "command": "jj-view.edit",
                    "when": "webviewSection == 'commit' && canEdit",
                    "group": "navigation"
                },
                {
                    "command": "jj-view.newBefore",
                    "when": "webviewSection == 'commit' && canNewBefore",
                    "group": "navigation"
                },
                {
                    "command": "jj-view.duplicate",
                    "when": "webviewSection == 'commit' && canDuplicate",
                    "group": "navigation"
                },
                {
                    "command": "jj-view.newMergeChange",
                    "when": "webviewSection == 'commit' && canMerge",
                    "group": "navigation"
                },
                {
                    "command": "jj-view.rebaseOntoSelected",
                    "when": "webviewSection == 'commit' && canRebaseOnto",
                    "group": "navigation"
                },
                {
                    "command": "jj-view.abandon",
                    "when": "webviewSection == 'commit' && canAbandon",
                    "group": "navigation"
                },
                {
                    "command": "jj-view.setBookmark",
                    "when": "webviewSection == 'commit'",
                    "group": "navigation"
                },
                {
                    "command": "jj-view.absorb",
                    "when": "webviewSection == 'commit' && canAbsorb",
                    "group": "navigation"
                },
                {
                    "command": "jj-view.showMultiFileDiff",
                    "when": "webviewSection == 'commit'",
                    "group": "navigation"
                }
            ],
            "scm/title": [
                {
                    "command": "jj-view.new",
                    "group": "navigation@1"
                },
                {
                    "command": "jj-view.setDescription",
                    "group": "navigation@2"
                },
                {
                    "command": "jj-view.commit",
                    "group": "navigation@3"
                },
                {
                    "command": "jj-view.refresh",
                    "group": "navigation@10"
                }
            ],
            "scm/resourceGroup/context": [
                {
                    "command": "jj-view.absorb",
                    "group": "inline",
                    "when": "scmResourceGroup == 'jj.group.workingCopy' && jj.parentMutable"
                },
                {
                    "command": "jj-view.showMultiFileDiff",
                    "group": "inline@1",
                    "when": "scmResourceGroupState =~ /^jj\\.group\\.ancestor/ || scmResourceGroup == 'jj.group.workingCopy'"
                },
                {
                    "command": "jj-view.abandon",
                    "group": "inline@2",
                    "when": "scmResourceGroup == 'jj.group.workingCopy'"
                },
                {
                    "command": "jj-view.squash",
                    "group": "inline@3",
                    "when": "scmResourceGroup == 'jj.group.workingCopy' && jj.parentMutable || scmResourceGroupState == 'jj.group.ancestor:squashable'"
                },
                {
                    "command": "jj-view.showDetails",
                    "group": "inline@4",
                    "when": "scmResourceGroupState =~ /^jj\\.group\\.ancestor/"
                },
                {
                    "command": "jj-view.edit",
                    "group": "inline@5",
                    "when": "scmResourceGroupState =~ /^jj\\.group\\.ancestor:(mutable|squashable)/"
                }
            ],
            "scm/resourceState/context": [
                {
                    "command": "jj-view.openFile",
                    "group": "inline@1",
                    "when": "scmResourceState =~ /^jj\\.resource\\.workingCopy/ || scmResourceState =~ /^jj\\.resource\\.ancestor/ || scmResourceState == 'jj.resource.conflict'"
                },
                {
                    "command": "jj-view.restore",
                    "group": "inline@2",
                    "when": "scmResourceState =~ /^jj\\.resource\\.workingCopy/"
                },
                {
                    "command": "jj-view.squashInto",
                    "group": "inline@3",
                    "when": "scmResourceState =~ /jj\\.resource.*:squashable:multi/"
                },
                {
                    "command": "jj-view.squash",
                    "group": "inline@4",
                    "when": "scmResourceState =~ /jj\\.resource.*:squashable/"
                },
                {
                    "command": "jj-view.moveToChild",
                    "icon": "$(git-merge)",
                    "group": "inline@5",
                    "when": "scmResourceState =~ /^jj\\.resource\\.ancestor/"
                },
                {
                    "command": "jj-view.moveToChild",
                    "icon": "$(git-merge)",
                    "group": "inline@6",
                    "when": "scmResourceState =~ /^jj\\.resource\\.workingCopy/ && jj.hasChild"
                }
            ],
            "scm/change/title": [
                {
                    "command": "jj-view.discardChange",
                    "group": "navigation",
                    "when": "originalResourceScheme == 'jj-view'"
                },
                {
                    "command": "jj-view.squashChange",
                    "group": "navigation",
                    "when": "originalResourceScheme == 'jj-view' && jj.parentMutable"
                }
            ],
            "editor/title": [
                {
                    "command": "jj-view.completeSquash",
                    "group": "navigation",
                    "when": "resourceFilename == 'SQUASH_MSG'"
                }
            ],
            "editor/context": [
                {
                    "command": "jj-view.moveToParentInDiff",
                    "group": "jj-view",
                    "when": "isInDiffEditor && jj.parentMutable"
                }
            ]
        },
        "views": {
            "scm": [
                {
                    "id": "jj-view.logView",
                    "name": "JJ Log",
                    "type": "webview"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run check-types && npm run lint && node esbuild.js --production",
        "build": "npm run check-types && npm run lint && node esbuild.js",
        "build:icons": "svgtofont -s media/custom-icons-src -o media/custom-icons",
        "watch": "npm-run-all -p watch:*",
        "watch:esbuild": "node esbuild.js --watch",
        "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
        "package": "vsce package",
        "publish": "ovsx publish && vsce publish",
        "clean:tests": "rimraf out",
        "build:tests": "npm run clean:tests && tsc -p . --outDir out",
        "watch-tests": "tsc -p . -w --outDir out",
        "pretest": "npm run build && npm run build:tests && npm run lint",
        "check-types": "tsc --noEmit",
        "lint": "npm run format && eslint src && npm run check-license",
        "check-license": "go run github.com/google/addlicense@v1.1.1 -check -s=only -ignore='node_modules/**' -ignore='dist/**' -ignore='out/**' -ignore='coverage/**' -ignore='.vscode-test/**' -ignore='.jj/**' -ignore='media/custom-icons/**' **",
        "fix-license": "go run github.com/google/addlicense@v1.1.1 -s=only -ignore='node_modules/**' -ignore='dist/**' -ignore='out/**' -ignore='coverage/**' -ignore='.vscode-test/**' -ignore='.jj/**' -ignore='media/custom-icons/**' **",
        "format": "prettier --write .",
        "check-format": "prettier --check .",
        "test": "npm-run-all -p --print-label test:unit test:integration:all",
        "test:integration": "node esbuild.js && npm run build:tests && vscode-test --config .vscode-test.mjs",
        "test:activation": "node esbuild.js && npm run build:tests && vscode-test --config .vscode-test-activation.mjs",
        "test:integration:all": "node esbuild.js && npm run build:tests && vscode-test --config .vscode-test.mjs && vscode-test --config .vscode-test-activation.mjs",
        "test:screenshots": "playwright test",
        "test:e2e": "node esbuild.js && npm run build:tests && playwright test -c playwright.e2e.config.ts",
        "test:unit": "vitest run",
        "release:encode": "ts-node .agents/scripts/encode-release-notes.ts"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.0",
        "@types/mocha": "^10.0.10",
        "@types/node": "22.x",
        "@types/parcel__watcher": "^2.0.5",
        "@types/react": "^19.2.7",
        "@types/react-dom": "^19.2.3",
        "@types/sinon": "^21.0.0",
        "@types/vscode": "^1.104.0",
        "@types/word-wrap": "^1.2.0",
        "@vscode/test-cli": "^0.0.12",
        "@vscode/test-electron": "^2.5.2",
        "@vscode/vsce": "^3.7.1",
        "esbuild": "^0.27.1",
        "eslint": "^9.39.1",
        "eslint-config-prettier": "^10.1.8",
        "npm-run-all": "^4.1.5",
        "ovsx": "^0.10.8",
        "playwright": "^1.58.0",
        "prettier": "^3.7.4",
        "rimraf": "^6.1.2",
        "sinon": "^21.0.1",
        "svgtofont": "^6.5.1",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.48.1",
        "vitest": "^4.0.16"
    },
    "dependencies": {
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/modifiers": "^9.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@parcel/watcher": "^2.5.6",
        "@vscode-elements/elements": "^2.4.0",
        "@vscode/codicons": "^0.0.44",
        "parse-diff": "^0.11.1",
        "react": "^19.2.3",
        "react-dom": "^19.2.3",
        "word-wrap": "^1.2.5"
    }
}
